{
  "extends": [
    "config:recommended"
  ],
  "prHourlyLimit": 10,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "non-breaking deps"
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "lockFileMaintenance": {
    "enabled": false
  }
}
