{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticPrefixFixDepsChoreOthers",
    ":maintainLockFilesWeekly",
    ":dependencyDashboard"
  ],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "schedule": [
    "after 8am and before 6pm on monday to friday"
  ],
  // Keep lockfiles fresh even if no dependency changed
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 6am on monday"
    ],
    "commitMessageAction": "maintain pnpm lockfiles"
  },
  // Replace ranges in package.json with updated versions
  "rangeStrategy": "replace",
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "pinDigests": true,
  // Group related dependencies together
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "groupName": "React ecosystem",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom",
        "eslint-plugin-react**"
      ]
    },
    {
      "groupName": "Build & tooling",
      "matchPackageNames": [
        "webpack",
        "vite",
        "rollup",
        "typescript"
      ]
    },
    {
      "groupName": "Linters & formatters",
      "matchPackageNames": [
        "eslint",
        "eslint**",
        "prettier",
        "prettier**",
        "stylelint",
        "stylelint**"
      ]
    },
    {
      "groupName": "Node.js types",
      "matchPackageNames": [
        "@types/node"
      ]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ]
    }
  ],
  "baseBranches": [
    "main"
  ],
  "enabledManagers": [
    "npm",
    "gomod",
    "dockerfile",
    "github-actions"
  ]
}
